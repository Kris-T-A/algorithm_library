{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vs2026-base",
      "hidden": true,
      "generator": "Visual Studio 18 2026",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/install/${presetName}",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug;Release;RelWithDebInfo"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "vs2026-x64",
      "displayName": "Visual Studio 2026 (x64)",
      "inherits": "vs2026-base",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "toolset": {
        "value": "host=x64",
        "strategy": "set"
      }
    },
    {
      "name": "vs2026-x86",
      "displayName": "Visual Studio 2026 (Win32)",
      "inherits": "vs2026-base",
      "architecture": {
        "value": "Win32",
        "strategy": "set"
      },
      "toolset": {
        "value": "host=x64",
        "strategy": "set"
      }
    },
    {
      "name": "vs2026-arm64",
      "displayName": "Visual Studio 2026 (ARM64)",
      "inherits": "vs2026-base",
      "architecture": {
        "value": "ARM64",
        "strategy": "set"
      },
      "toolset": {
        "value": "host=x64",
        "strategy": "set"
      }
    },
    {
      "name": "vs2026-x64-clang",
      "displayName": "Visual Studio 2026 (x64, ClangCL)",
      "inherits": "vs2026-base",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "toolset": {
        "value": "ClangCL,host=x64",
        "strategy": "set"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "vs2026-x64-debug",
      "displayName": "x64 Debug",
      "configurePreset": "vs2026-x64",
      "configuration": "Debug"
    },
    {
      "name": "vs2026-x64-release",
      "displayName": "x64 Release",
      "configurePreset": "vs2026-x64",
      "configuration": "Release"
    },
    {
      "name": "vs2026-x64-relwithdebinfo",
      "displayName": "x64 RelWithDebInfo",
      "configurePreset": "vs2026-x64",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "vs2026-x86-debug",
      "displayName": "x86 Debug",
      "configurePreset": "vs2026-x86",
      "configuration": "Debug"
    },
    {
      "name": "vs2026-x86-release",
      "displayName": "x86 Release",
      "configurePreset": "vs2026-x86",
      "configuration": "Release"
    },
    {
      "name": "vs2026-arm64-debug",
      "displayName": "ARM64 Debug",
      "configurePreset": "vs2026-arm64",
      "configuration": "Debug"
    },
    {
      "name": "vs2026-arm64-release",
      "displayName": "ARM64 Release",
      "configurePreset": "vs2026-arm64",
      "configuration": "Release"
    },
    {
      "name": "vs2026-x64-clang-release",
      "displayName": "x64 ClangCL Release",
      "configurePreset": "vs2026-x64-clang",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "vs2026-x64-debug",
      "configurePreset": "vs2026-x64",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "stopOnFailure": false
      }
    },
    {
      "name": "vs2026-x64-release",
      "configurePreset": "vs2026-x64",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "stopOnFailure": false
      }
    }
  ]
}
